{
  ssh: {
    // user: 'admin',                   // default SSH user; leave blank to prompt in browser
    host:       'localhost',            // SSH target — the NAS itself
    auth:       'password',             // authentication method: "password" or "publickey,password"
    port:       22,                     // DSM SSH port (Control Panel > Terminal & SNMP)
    knownHosts: '/dev/null',            // skip host-key checking for localhost loopback
  },
  server: {
    base:   '/wetty/',                  // URL path served by WeTTY
    port:   13338,                      // listening port
    host:   '0.0.0.0',                  // bind on all interfaces
    title:  'WeTTY — NAS Terminal',     // browser tab title
    bypassHelmet: false,
  },
  forceSSH: false,    // set true if you want SSH even when WeTTY runs as root
  command:  'login',  // use 'login' so the full PAM login chain runs via SSH
}
